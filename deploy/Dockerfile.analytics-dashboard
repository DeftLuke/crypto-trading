FROM node:20-slim AS build
WORKDIR /app

COPY analytics-dashboard/package*.json ./
RUN npm ci

COPY analytics-dashboard/ ./

ARG NEXT_PUBLIC_RESEARCH_API_URL=/api/research
ARG NEXT_PUBLIC_TRADING_API_URL=/api/trading
ARG NEXT_PUBLIC_WS_URL=wss://api.deftluke.online/ws
ARG NEXT_PUBLIC_SUPABASE_URL=
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=
ARG TRADING_API_URL=http://backend:3001
ARG RESEARCH_API_URL=http://research-api:8100

ENV NEXT_PUBLIC_RESEARCH_API_URL=$NEXT_PUBLIC_RESEARCH_API_URL
ENV NEXT_PUBLIC_TRADING_API_URL=$NEXT_PUBLIC_TRADING_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV TRADING_API_URL=$TRADING_API_URL
ENV RESEARCH_API_URL=$RESEARCH_API_URL

RUN npm run build

FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000

COPY --from=build /app/package*.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/.next ./.next
COPY --from=build /app/public ./public
COPY --from=build /app/next.config.ts ./next.config.ts

EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:3000').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["npm", "run", "start"]
