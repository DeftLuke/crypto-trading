FROM node:22-slim AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

COPY analytics-dashboard/package*.json ./
RUN npm ci --omit=dev --no-audit --no-fund --prefer-offline

COPY analytics-dashboard/.next ./.next
COPY analytics-dashboard/public ./public
COPY analytics-dashboard/next.config.ts ./next.config.ts

EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD node -e "require(\"http\").get(\"http://127.0.0.1:3000/login\", r => process.exit(r.statusCode < 500 ? 0 : 1)).on(\"error\", () => process.exit(1))"

CMD ["npm", "run", "start"]
