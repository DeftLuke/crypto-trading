# =============================================================================
# Production env — copy to deploy/.env
# Kali: bash scripts/kali-deploy.sh  |  VPS: docker compose --profile tunnel up -d
# =============================================================================

# --- Cloudflare (required) ---
# Create at: Cloudflare Zero Trust → Networks → Tunnels → Configure → Docker
# Paste the token here. Move tunnel OFF your Windows PC when VPS is live.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Public URLs (unchanged — Cloudflare DNS stays the same) ---
PUBLIC_API_URL=https://api.deftluke.online
PUBLIC_WS_URL=wss://api.deftluke.online
N8N_HOST=n8n.deftluke.online
N8N_BASE_URL=https://n8n.deftluke.online

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# --- Telegram (bot runs inside backend container 24/7) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI (internal Docker URLs set in docker-compose; these are model names) ---
AI_API_KEY=your-ai-api-key
OLLAMA_MODEL=mistral:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- n8n webhooks (public URLs) ---
N8N_SIGNAL_WEBHOOK_URL=https://n8n.deftluke.online/webhook/signal-notify
N8N_EXECUTE_WEBHOOK_URL=https://n8n.deftluke.online/webhook/trade-execute
N8N_AI_WEBHOOK_URL=https://n8n.deftluke.online/webhook/ai-assistant
N8N_API_KEY=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# --- Strategy ---
MIN_SIGNAL_CONFIDENCE=70
MAX_DAILY_TRADES=5
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
SCAN_INTERVAL_MS=60000
TZ=Asia/Dhaka

# CoinGecko Demo API
COINGECKO_API_KEY=your-cg-demo-api-key

# Web search — Serper.dev
SERPER_API_KEY=your-serper-api-key
