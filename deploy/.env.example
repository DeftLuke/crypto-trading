# =============================================================================
# Production env — copy to deploy/.env
# Kali: bash scripts/kali-deploy.sh  |  VPS: docker compose --profile tunnel up -d
# =============================================================================

# --- Cloudflare (required) ---
# Create at: Cloudflare Zero Trust → Networks → Tunnels → Configure → Docker
 Paste the token here. Move tunnel OFF your Windows PC when VPS is live.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Public URLs (unchanged — Cloudflare DNS stays the same) ---
PUBLIC_API_URL=https://api.deftluke.online
PUBLIC_WS_URL=wss://api.deftluke.online
PUBLIC_APP_URL=https://trade.deftluke.online
PUBLIC_PLATFORM_URL=https://terminal.deftluke.online
N8N_HOST=n8n.deftluke.online
N8N_BASE_URL=https://n8n.deftluke.online

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=

# --- Research / Institutional Platform ---
RESEARCH_API_URL=http://research-api:8100
NEXT_PUBLIC_RESEARCH_API_URL=/api/research
NEXT_PUBLIC_TRADING_API_URL=/api/trading
# Local Parquet store for OHLCV (Binance Vision archives — NOT Supabase)
MARKET_DATA_ROOT=/data/market_data
MARKET_DATA_ENABLED=true
MARKET_DATA_AUTO_DOWNLOAD=true
MARKET_DATA_AUTO_UPDATE=true
MARKET_DATA_PHASE_SIZE=50
MARKET_DATA_UNIVERSE_SIZE=200
MARKET_DATA_MIN_QUOTE_VOLUME=500000
# Set CANDLE_BACKFILL_ENABLED=true to force legacy per-symbol backfill from backend
CANDLE_BACKFILL_ENABLED=false
CANDLE_INGESTION_ENABLED=true
CONTROL_AUTO_TRADING=true
CONTROL_MANUAL_APPROVAL=true

# Node.js heap ceiling for backend (scanner, backtests, AI). Grows on demand up to this limit.
NODE_OPTIONS=--max-old-space-size=16384
CONTROL_TRADING_MODE=demo
SCANNER_AUTO_START=true
SIGNAL_ENGINE=institutional-smc
LEGACY_SMC_MTF_ENABLED=false
INSTITUTIONAL_SMC_MIN_SCORE=80
SCANNER_MAX_PAIRS=200
# Market scanner runs at boot. Backend uses Docker --restart always + watchdog if Node crashes during scans.
TRADE_APPROVAL_PASSCODE=8888
# Protect /api/execute from anonymous public calls (auto-generated by production-kali.sh)
INTERNAL_API_SECRET=
CORS_ORIGINS=https://trade.deftluke.online,https://terminal.deftluke.online
RATE_LIMIT_PER_MIN=120
MEMORY_EMBEDDING_PROVIDER=hash

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SIGNATURE_TYPE=hmac
BINANCE_PRIVATE_KEY_PATH=
BINANCE_DEMO_PRIVATE_KEY_PATH=
# Demo trading (paper futures): https://demo.binance.com — keys from Demo Trading UI
BINANCE_DEMO=true
BINANCE_TESTNET=true
# Live mainnet: BINANCE_DEMO=false BINANCE_TESTNET=false

# --- Telegram (bot runs inside backend container 24/7) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Production Telegram is owned by n8n to avoid Telegram 409 polling conflicts.
TELEGRAM_DELIVERY=n8n
# Backend polls Telegram for AI chat + trade buttons when delivery=n8n (n8n webhook = outbound only)
TELEGRAM_POLLING_ENABLED=false

# --- Telegram Signal Ingestion Service (Telethon user session) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
MAIN_TRADING_API_KEY=
EXTERNAL_SIGNAL_INGESTION_KEY=
EXTERNAL_SIGNAL_MIN_VALIDATION_SCORE=70
EXTERNAL_SIGNAL_MAX_AGE_MINUTES=15
TG_TEST_MODE=true
AI_PARSER_ENABLED=true
AI_PARSER_URL=http://host.docker.internal:8080/chat
AI_GATEWAY_URL=http://host.docker.internal:8080

# OpenClaw — text LLM for assistant chat (Kali host :18789, token from ~/.openclaw/openclaw.json)
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_MODEL=openclaw/default
OPENCLAW_ENABLED=true
AI_PARSER_API_KEY=
AI_PARSER_MODEL=qwen2.5:7b-instruct
# Chart / TradingView screenshot signals (requires: ollama pull llava:7b on host)
AI_VISION_MODEL=llava:7b

# --- AI (internal Docker URLs set in docker-compose; these are model names) ---
# Primary text LLM is now the OpenClaw gateway (see OPENCLAW_* above). Ollama is
# a local fallback only. Set OLLAMA_ENABLED=false to skip it entirely — no model
# downloads, no 120s timeouts when the container isn't running.
OLLAMA_ENABLED=false
AI_API_KEY=your-ai-api-key
OLLAMA_MODEL=mistral:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- n8n webhooks (public URLs) ---
N8N_SIGNAL_WEBHOOK_URL=https://n8n.deftluke.online/webhook/signal-notify
N8N_EXECUTE_WEBHOOK_URL=https://n8n.deftluke.online/webhook/trade-execute
N8N_AI_WEBHOOK_URL=https://n8n.deftluke.online/webhook/ai-assistant
N8N_EVENT_WEBHOOK_URL=https://n8n.deftluke.online/webhook/tradegpt-event
N8N_API_KEY=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# --- Strategy ---
# Institutional SMC v2 (CP6) — Python engine via research-api
# Runtime toggle also on Risk dashboard (signal_engine setting)
INSTITUTIONAL_SMC_ENABLED=false
SMC_ENGINE_VERSION=v2
SIGNAL_ENGINE=smc-mtf
# smc-mtf | institutional-smc — default boot engine (overridable on Risk page)
INSTITUTIONAL_SMC_MIN_SCORE=80
INSTITUTIONAL_SMC_REJECT_OFFLINE=true
INSTITUTIONAL_SMC_BATCH_SIZE=25
INSTITUTIONAL_SMC_TF_TREND=1d
INSTITUTIONAL_SMC_TF_BIAS=4h
INSTITUTIONAL_SMC_TF_SETUP=1h
INSTITUTIONAL_SMC_TF_ENTRY=15m

MAX_DAILY_TRADES=5
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
# Phase 4 backtest gate (soft by default; set STRICT=true to block signals without 1y backtest)
BACKTEST_GATE_MIN_SCORE=55
BACKTEST_GATE_MIN_WIN_RATE=45
BACKTEST_GATE_MIN_DAYS=300
BACKTEST_GATE_STRICT=false
SCAN_INTERVAL_MS=60000
TZ=Asia/Dhaka

# CoinGecko Demo API
COINGECKO_API_KEY=your-cg-demo-api-key

# Dune Analytics — on-chain data (https://dune.com/settings/api)
DUNE_API_KEY=
# Query IDs — fork private dashboards on dune.com to YOUR account, run once, paste new IDs
# Solana (optional — maditim dashboard is private until forked):
# https://dune.com/maditim/solmemecoinstradewallets
DUNE_SOL_WALLETS_QUERY_ID=
DUNE_SOL_TRADES_QUERY_ID=
DUNE_SOL_TRADES_RECENT_QUERY_ID=3641835
# Sol memecoin token list (forked from maditim dashboard)
DUNE_SOL_TOKENS_QUERY_ID=7714204
# TRON sunpump memecoin wallets & trades
DUNE_TRON_WALLETS_QUERY_ID=4003316
DUNE_TRON_TRADES_RECENT_QUERY_ID=4009866
DUNE_TRON_TRADES_QUERY_ID=4003641
# Base network daily stats (not individual wallet list)
DUNE_BASE_DAILY_STATS_QUERY_ID=5797617

# Smart Wallet Scanner
WALLET_SCANNER_ENABLED=true
WALLET_SCANNER_INTERVAL_MS=900000
WALLET_SCANNER_DAILY_HOUR=6
N8N_WALLET_SCANNER_WEBHOOK_URL=https://n8n.deftluke.online/webhook/wallet-scanner

# Web search — Serper.dev
SERPER_API_KEY=your-serper-api-key

# --- Freqtrade removed ---
# TradeGPT now uses the native backend + Control Center pipeline.
FREQTRADE_ENABLED=false
