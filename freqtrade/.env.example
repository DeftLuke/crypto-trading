# Freqtrade bot settings (also add to deploy/.env for Docker)
FREQTRADE_STRATEGY=TradeGPT_RSI_Momentum
FREQTRADE_DRY_RUN=true
FREQTRADE_API_USER=freqtrader
FREQTRADE_API_PASSWORD=change-me-freqtrade-password
