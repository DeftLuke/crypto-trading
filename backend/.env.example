PORT=3001

NODE_ENV=production



# Supabase

SUPABASE_URL=https://your-project.supabase.co

SUPABASE_SERVICE_KEY=your-service-key

SUPABASE_PUBLISHABLE_KEY=your-publishable-key

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres"



# Binance Futures (use testnet first!)

BINANCE_API_KEY=

BINANCE_API_SECRET=

BINANCE_TESTNET=true



# Telegram

TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=



# Public domains (deftluke.online)

PUBLIC_API_URL=https://api.deftluke.online

# Production VPS (Docker internal — see deploy/docker-compose.yml):
# AI_GATEWAY_URL=http://ai-gateway:8080
# OLLAMA_VIA_GATEWAY=true

# Public / dev fallback:
AI_GATEWAY_URL=https://ai.deftluke.online
AI_GATEWAY_PUBLIC_URL=https://ai.deftluke.online
AI_API_KEY=your-ai-api-key
OLLAMA_URL=https://ai.deftluke.online
OLLAMA_VIA_GATEWAY=true
OLLAMA_MODEL=mistral:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# n8n (public URLs — runs on same VPS in production)

N8N_BASE_URL=https://n8n.deftluke.online

N8N_SIGNAL_WEBHOOK_URL=https://n8n.deftluke.online/webhook/signal-notify

N8N_EXECUTE_WEBHOOK_URL=https://n8n.deftluke.online/webhook/trade-execute

N8N_AI_WEBHOOK_URL=https://n8n.deftluke.online/webhook/ai-assistant

N8N_API_KEY=your-n8n-api-key



# CoinGecko Demo API — chart data + live prices (header: x-cg-demo-api-key)
COINGECKO_API_KEY=your-cg-demo-api-key

# Web search (Telegram bot) — Serper.dev Google search (recommended)
SERPER_API_KEY=your-serper-api-key
# Optional fallback: SERPAPI_KEY=

MIN_SIGNAL_CONFIDENCE=70

MAX_DAILY_TRADES=5

RISK_PER_TRADE=0.01

MAX_DAILY_LOSS=0.03

VOLATILITY_THRESHOLD=0.30

DEFAULT_ENTRY_TIMEFRAME=5m

SCAN_INTERVAL_MS=60000

# RSI mandatory gates
RSI_BUY_MAX=30
RSI_BUY_IDEAL=25
RSI_SELL_MIN=70
RSI_SELL_IDEAL=80

# Signal dedup — 1 hour cooldown per symbol+direction
SIGNAL_COOLDOWN_MS=3600000

# Scan all futures pairs (min 24h quote volume USDT)
MIN_PAIR_VOLUME=500000
SCAN_BATCH_SIZE=10

# Agent web search rate limit per hour
MAX_AGENT_SEARCHES_PER_HOUR=5
