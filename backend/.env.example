PORT=3001
NODE_ENV=production

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres"

# Binance Futures (use testnet first!)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public domains (deftluke.online — no Tailscale IPs in app config)
PUBLIC_API_URL=https://api.deftluke.online
AI_GATEWAY_URL=https://ai.deftluke.online
AI_GATEWAY_PUBLIC_URL=https://ai.deftluke.online
AI_API_KEY=your-ai-api-key
OLLAMA_URL=https://ai.deftluke.online
OLLAMA_VIA_GATEWAY=true
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# n8n (Kali via Cloudflare)
N8N_BASE_URL=https://n8n.deftluke.online
N8N_SIGNAL_WEBHOOK_URL=https://n8n.deftluke.online/webhook/signal-notify
N8N_EXECUTE_WEBHOOK_URL=https://n8n.deftluke.online/webhook/trade-execute
N8N_AI_WEBHOOK_URL=https://n8n.deftluke.online/webhook/ai-assistant

# Strategy settings
MIN_SIGNAL_CONFIDENCE=70
MAX_DAILY_TRADES=5
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
VOLATILITY_THRESHOLD=0.30
DEFAULT_ENTRY_TIMEFRAME=5m
SCAN_INTERVAL_MS=60000
