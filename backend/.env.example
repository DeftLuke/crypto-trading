PORT=3001

NODE_ENV=production



# Supabase

SUPABASE_URL=https://your-project.supabase.co

SUPABASE_SERVICE_KEY=your-service-key

SUPABASE_PUBLISHABLE_KEY=your-publishable-key

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres"



# Binance Futures — separate demo & live keys
BINANCE_TRADING_MODE=demo
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=
BINANCE_DEMO=true
BINANCE_TESTNET=true



# Telegram

TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=

TELEGRAM_DELIVERY=n8n

TELEGRAM_POLLING_ENABLED=false
# Comma-separated Telegram user IDs allowed to chat (defaults to TELEGRAM_CHAT_ID only)
TELEGRAM_ALLOWED_USERS=
TELEGRAM_TASKS_ENABLED=true
TELEGRAM_ASSISTANT_ENABLED=true



# Public domains (deftluke.online)

PUBLIC_API_URL=https://api.deftluke.online

# Production VPS (Docker internal — see deploy/docker-compose.yml):
# AI_GATEWAY_URL=http://ai-gateway:8080
# OLLAMA_VIA_GATEWAY=true

# Public / dev fallback:
AI_GATEWAY_URL=https://ai.deftluke.online
AI_GATEWAY_PUBLIC_URL=https://ai.deftluke.online
AI_API_KEY=your-ai-api-key
OLLAMA_URL=https://ai.deftluke.online
OLLAMA_VIA_GATEWAY=true
OLLAMA_MODEL=mistral:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenClaw — primary text LLM for assistant chat (strategy building, no vision)
# Kali host gateway listens on 127.0.0.1:18789; Docker backend uses host.docker.internal
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
OPENCLAW_MODEL=openclaw/default
OPENCLAW_ENABLED=true

# n8n (public URLs — runs on same VPS in production)

N8N_BASE_URL=https://n8n.deftluke.online

N8N_SIGNAL_WEBHOOK_URL=https://n8n.deftluke.online/webhook/signal-notify

# Trade safety monitor (missing SL/TP scan + auto-recovery)
TRADE_SAFETY_INTERVAL_MS=30000
TRADE_SAFETY_RECOVERY=true
TRADE_SAFETY_EMERGENCY_CLOSE=true
# Keep URL for external/manual triggers only; workflow skips when already_executed=true.
N8N_EXECUTE_WEBHOOK_URL=https://n8n.deftluke.online/webhook/trade-execute

N8N_AI_WEBHOOK_URL=https://n8n.deftluke.online/webhook/ai-assistant

N8N_EVENT_WEBHOOK_URL=https://n8n.deftluke.online/webhook/tradegpt-event

N8N_API_KEY=your-n8n-api-key



# CoinGecko Demo API — chart data + live prices (header: x-cg-demo-api-key)
COINGECKO_API_KEY=your-cg-demo-api-key

# Dune Analytics — on-chain SQL / saved queries (header: X-DUNE-API-KEY)
# MCP for Cursor: .cursor/mcp.json
DUNE_API_KEY=

# Web search (Telegram bot) — Serper.dev Google search (recommended)
SERPER_API_KEY=your-serper-api-key
# Optional fallback: SERPAPI_KEY=

MIN_SIGNAL_CONFIDENCE=70

MAX_DAILY_TRADES=5

RISK_PER_TRADE=0.01

MAX_DAILY_LOSS=0.03

VOLATILITY_THRESHOLD=0.30

DEFAULT_ENTRY_TIMEFRAME=5m

SCAN_INTERVAL_MS=60000

# RSI mandatory gates
RSI_BUY_MAX=30
RSI_BUY_IDEAL=25
RSI_SELL_MIN=70
RSI_SELL_IDEAL=80

# Signal dedup — 1 hour cooldown per symbol+direction
SIGNAL_COOLDOWN_MS=3600000

# Scan all futures pairs (min 24h quote volume USDT) — legacy engine only
MIN_PAIR_VOLUME=500000
SCAN_BATCH_SIZE=10
# Signal engine: institutional-smc (v2) only — legacy smc-mtf disabled by default
SIGNAL_ENGINE=institutional-smc
LEGACY_SMC_MTF_ENABLED=false
INSTITUTIONAL_SMC_MIN_SCORE=80

# Agent web search rate limit per hour
MAX_AGENT_SEARCHES_PER_HOUR=5
