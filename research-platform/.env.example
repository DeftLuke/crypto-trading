# Application
APP_NAME=research-platform
APP_ENV=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8100

# ── Supabase PostgreSQL (recommended for production) ──────────────────────────
# Option A — paste full connection string from Supabase Dashboard → Settings → Database
# Use "Session pooler" or "Direct connection" URI; asyncpg driver is added automatically.
#
# Option A — Session/Transaction pooler (recommended on Windows; direct host is IPv6-only)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL=true

# Option B — direct connection (Linux/VPS with IPv6, or Supabase SQL Editor for migrations)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Option B — build URL from parts (leave DATABASE_URL as local default if using this)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
# SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
# SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Local Docker Postgres (dev only — use: docker compose --profile local up) ─
# DATABASE_URL=postgresql+asyncpg://research:research@localhost:5433/research_db
# DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6380/0

# Local Parquet root (mount volume in production)
DATA_ROOT=./data

# Sync defaults
DEFAULT_EXCHANGES=binance,bybit,okx,hyperliquid
DEFAULT_TIMEFRAMES=1m,5m,15m,30m,1h,4h,1d
SYNC_BATCH_SIZE=1000
SYNC_RATE_LIMIT_MS=200

# Exchange keys (optional — public OHLCV works without keys)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Scheduler
SCHEDULER_ENABLED=true
SYNC_INTERVAL_MINUTES=15

# ── Phase 5 — Qdrant Memory Layer ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
MEMORY_ENABLED=true
MEMORY_LOW_RAM=false
# hash (default, no GPU) | bge-small | bge-base | bge-large | openai
MEMORY_EMBEDDING_PROVIDER=hash
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_VECTOR_SIZE=384
MEMORY_WORKER_INTERVAL_MINUTES=10

# ── Phase 6 — AI Research Agent ───────────────────────────────────────────────
AGENT_ENABLED=true
AGENT_AUTO_START=false
AGENT_LOW_RAM=false
AGENT_CYCLE_INTERVAL_MINUTES=7
AGENT_MAX_HYPOTHESES=12
AGENT_MAX_BACKTESTS_PER_CYCLE=5
AGENT_META_LEARNING=true
AGENT_META_THRESHOLD=0.35

# ── Phase 7 — Paper Trading Engine ──────────────────────────────────────────────
PAPER_ENABLED=true
PAPER_AUTO_START=false
PAPER_DEFAULT_BALANCE=1000
PAPER_DEFAULT_LEVERAGE=50
PAPER_MARGIN_PCT=0.5
PAPER_SIZING_MODE=margin_pct
PAPER_MAX_POSITIONS=20
PAPER_MAX_DAILY_LOSS_PCT=3.0
PAPER_MAX_DRAWDOWN_PCT=20.0
PAPER_SLIPPAGE_BPS=5.0
PAPER_LATENCY_MS=0
PAPER_VALIDATION_MIN_TRADES=100
PAPER_VALIDATION_MIN_PF=1.5
PAPER_VALIDATION_MIN_SHARPE=1.2
PAPER_VALIDATION_MAX_DD=20.0
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Phase 8 — Live Trading Engine ───────────────────────────────────────────────
LIVE_ENABLED=true
LIVE_AUTO_START=false
LIVE_DRY_RUN=true
LIVE_DEFAULT_BALANCE=1000
LIVE_DEFAULT_LEVERAGE=50
LIVE_MAX_LEVERAGE=50
LIVE_MARGIN_PCT=0.5
LIVE_SIZING_MODE=margin_pct
LIVE_MAX_POSITIONS=20
LIVE_MAX_DAILY_LOSS_PCT=3.0
LIVE_MAX_DRAWDOWN_PCT=20.0
LIVE_MAX_EXPOSURE_PCT=80.0
LIVE_MAX_SYMBOL_EXPOSURE_PCT=40.0
LIVE_MAX_MARGIN_USAGE_PCT=90.0
LIVE_API_ERROR_THRESHOLD=10
LIVE_REQUIRE_APPROVAL=true
LIVE_ALLOW_MANUAL=true
LIVE_SIMULATED_LATENCY_MS=50
LIVE_MONITOR_INTERVAL_SEC=2.0
BINANCE_TESTNET=false
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ── Phase 9 — n8n AI Agent & Operations ───────────────────────────────────────────
OPERATIONS_ENABLED=true
AI_GATEWAY_URL=https://ai.deftluke.online
# AI_API_KEY=
# AI_OPENAI_API_URL=
# AI_OPENAI_API_KEY=
# AI_OPENAI_MODEL=gpt-4o-mini
N8N_BASE_URL=https://n8n.deftluke.online
# N8N_API_KEY=
# N8N_WEBHOOK_URL=https://n8n.deftluke.online/webhook/platform-event
# DISCORD_WEBHOOK_URL=
OPERATIONS_DAILY_SUMMARY=true

# ── Phase 10 — Enterprise Control Center ────────────────────────────────────────
CONTROL_ENABLED=true
CONTROL_TRADING_MODE=demo
CONTROL_AUTO_TRADING=false
CONTROL_MANUAL_APPROVAL=true
CONTROL_DEFAULT_EXCHANGE=binance
TRADE_APPROVAL_PASSCODE=8888
# OpenAI-compatible embedding API (optional)
# MEMORY_EMBEDDING_API_URL=https://api.openai.com/v1
# MEMORY_EMBEDDING_API_KEY=
